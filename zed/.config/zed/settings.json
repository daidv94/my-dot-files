// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "tab_bar": {
    "show": false
  },
  "scrollbar": {
    "show": "never"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "proxy": "",
  "which_key": {
    "enabled": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "vim_mode": true,
  "terminal": {
    "toolbar": {
      "breadcrumbs": true
    },
    "font_size": 14.0,
    "font_family": "JetBrainsMono Nerd Font",
    "cursor_shape": "bar",
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
  },
  "preview_tabs": {
    "enabled": false,
  },
  "relative_line_numbers": "enabled",
  "sticky_scroll": {
    "enabled": true,
  },
  "vertical_scroll_margin": 999.0,
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_shape": "bar",
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "show_whitespaces": "all",
  "soft_wrap": "none",
  "tab_size": 2,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
}
